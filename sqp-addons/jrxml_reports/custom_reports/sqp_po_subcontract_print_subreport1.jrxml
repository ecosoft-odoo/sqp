<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="sqp_po_subcontract_print_subreport1" language="groovy" pageWidth="555" pageHeight="802" columnWidth="555" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="id" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[(select null id, null date_due, null percent, null invoice_amount, 100 balance_percent, po.amount_net balance_amount
from purchase_order po
where po.id = $P{id})
union all
(select row_number() over (order by ai.date_invoice) id, ai.date_due, ai.amount_net / po.amount_net * 100 percent, ai.amount_net invoice_amount, 100 - sum(ai.amount_net / po.amount_net * 100) over (order by ai.date_invoice) balance_percent, po.amount_net - sum(ai.amount_net) over (order by ai.date_invoice) balance_amount from account_invoice ai
join purchase_invoice_rel pir on ai.id = pir.invoice_id
join purchase_order po on po.id = pir.purchase_id
where ai.state in ('open','paid')
and pir.purchase_id = $P{id}
order by ai.date_invoice)]]>
	</queryString>
	<field name="date_due" class="java.util.Date"/>
	<field name="percent" class="java.lang.Number"/>
	<field name="invoice_amount" class="java.lang.Number"/>
	<field name="balance_percent" class="java.lang.Number"/>
	<field name="balance_amount" class="java.lang.Number"/>
	<field name="id" class="java.lang.Integer"/>
	<variable name="total_percent" class="java.lang.Number" calculation="Sum">
		<variableExpression><![CDATA[$F{percent}]]></variableExpression>
	</variable>
	<variable name="total_invoice_amount" class="java.lang.Number" calculation="Sum">
		<variableExpression><![CDATA[$F{invoice_amount}]]></variableExpression>
	</variable>
